repeat task.wait() until game:IsLoaded()
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local LocalPlayer = Players.LocalPlayer
repeat task.wait() until LocalPlayer

-- ===================== SETUP SAMA PERSIS =====================
local SharedModules = ReplicatedStorage:WaitForChild("SharedModules")
local SharedData = ReplicatedStorage:WaitForChild("SharedData")

local function safeRequire(inst)
    if not inst then return nil end
    local ok, result = pcall(require, inst)
    if ok then return result end
    return nil
end

local Networking = safeRequire(SharedModules:WaitForChild("Networking"))
local PlayerStateClient = safeRequire(ReplicatedStorage:WaitForChild("ClientModules"):WaitForChild("PlayerStateClient"))

-- Notifikasi Bahasa Indonesia
local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title or "Auto Kirim",
            Text = text or "",
            Duration = duration or 4
        })
    end)
end

local function cleanUsername(name)
    name = tostring(name or "")
    name = name:gsub("^%s*@?", ""):gsub("%s+$", "")
    return name
end

local function lookupPlayer(username)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.LookupPlayer then
        return nil, "Layanan pencarian tidak tersedia"
    end
    local ok, userId, displayName = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(username)
    end)
    if not ok or type(userId) ~= "number" or userId <= 0 then
        return nil, "Tidak menemukan pemain: " .. tostring(username)
    end
    if userId == LocalPlayer.UserId then
        return nil, "Tidak bisa kirim ke diri sendiri"
    end
    return userId, tostring(displayName or username)
end

local function waitLocalReplica(timeout)
    local replica = nil
    if type(PlayerStateClient.WaitForLocalReplica) == "function" then
        local ok, result = pcall(function() return PlayerStateClient:WaitForLocalReplica(timeout or 30) end)
        if ok then replica = result end
    end
    if not replica and type(PlayerStateClient.GetLocalReplica) == "function" then
        local started = os.clock()
        repeat
            local ok, result = pcall(function() return PlayerStateClient:GetLocalReplica() end)
            if ok and result then replica = result; break end
            task.wait(0.25)
        until os.clock() - started > (timeout or 30)
    end
    return replica
end

local function getInventory()
    local replica = waitLocalReplica(30)
    if not replica or type(replica.Data) ~= "table" or type(replica.Data.Inventory) ~= "table" then return nil end
    return replica.Data.Inventory
end

-- ✅ FUNGSI CARI: CUKUP NAMA UTAMA, TANPA "SEED"
local function findItems(baseName, inv)
    local results = {}
    local baseNorm = string.lower(baseName:gsub("%s+", ""))

    if type(inv.Seeds) == "table" then
        for seedKey, seedEntry in pairs(inv.Seeds) do
            local keyNorm = string.lower(tostring(seedKey):gsub("%s+", ""))
            -- Hilangkan bagian "Seed" agar cocok hanya nama dasarnya
            keyNorm = keyNorm:gsub("seed.*$", "")

            local amount = 0
            if type(seedEntry) == "table" then
                amount = tonumber(seedEntry.Count or seedEntry.Amount or seedEntry.Quantity or seedEntry.Stack or 0) or 0
            elseif type(seedEntry) == "number" then
                amount = seedEntry
            end

            if keyNorm == baseNorm and amount > 0 then
                table.insert(results, {
                    Category = "Seeds",
                    ItemKey = seedKey,
                    Available = amount,
                    DisplayName = seedKey
                })
            end
        end
    end

    if type(inv.HarvestedFruits) == "table" then
        for itemKey, entry in pairs(inv.HarvestedFruits) do
            if type(entry) == "table" and entry.Id ~= nil then
                local name = tostring(entry.FruitName or entry.Name or entry.DisplayName or itemKey)
                local nameNorm = string.lower(name:gsub("%s+", ""))
                if nameNorm == baseNorm then
                    table.insert(results, {
                        Category = "HarvestedFruits",
                        ItemKey = itemKey,
                        Available = 1,
                        DisplayName = name
                    })
                end
            end
        end
    end

    if type(inv.Pets) == "table" then
        for itemKey, entry in pairs(inv.Pets) do
            if type(entry) == "table" and entry.Id ~= nil then
                local name = tostring(entry.Name or entry.PetName or entry.Species or entry.DisplayName or itemKey)
                local nameNorm = string.lower(name:gsub("%s+", ""))
                if nameNorm == baseNorm then
                    table.insert(results, {
                        Category = "Pets",
                        ItemKey = itemKey,
                        Available = 1,
                        DisplayName = name
                    })
                end
            end
        end
    end

    return results
end

-- ✅ FUNGSI KIRIM SAMA PERSIS YANG WORK
local function sendBatch(userId, payload, note)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.SendBatch then
        return false, "Layanan pengiriman tidak tersedia"
    end
    local ok, result, message = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, payload, tostring(note or ""))
    end)
    if not ok then return false, "Kesalahan: " .. tostring(result) end
    if result == true then return true, "Berhasil dikirim" end
    return false, tostring(message or "Gagal dikirim")
end

local function sendAll(userId, items, note)
    local payload = {}
    local total = 0
    for _, item in ipairs(items) do
        table.insert(payload, {
            Category = item.Category,
            ItemKey = item.ItemKey,
            Count = item.Available
        })
        total += item.Available
    end
    if #payload == 0 then return 0, "Tidak ada item" end
    local ok, msg = sendBatch(userId, payload, note)
    if ok then return total, nil else return 0, msg end
end

