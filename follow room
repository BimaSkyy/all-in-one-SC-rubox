repeat task.wait() until game:IsLoaded()
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local StarterGui = game:GetService("StarterGui")
local LocalPlayer = Players.LocalPlayer
repeat task.wait() until LocalPlayer

-- Bisa jalan di SEMUA akun
local HttpGet = game.HttpGet
local TAUTAN = "https://raw.githubusercontent.com/BimaSkyy/all-in-one-SC-rubox/refs/heads/main/room"

local function notify(judul, teks)
    pcall(function()
        StarterGui:SetCore("SendNotification", {Title=judul, Text=teks, Duration=3})
    end)
    print("["..LocalPlayer.Name.."] "..judul..": "..teks)
end

local function cekDanGabung()
    local ok, isi = pcall(function()
        return HttpGet(game, TAUTAN)
    end)

    if not ok then
        notify("❌ Gagal Baca", "Tidak bisa hubungi GitHub")
        return
    end
    if not isi or isi == "" then
        notify("⚠️ Kosong", "File ada tapi isinya kosong")
        return
    end
    if isi:find("Unable to parse") or isi:find("error") or isi:find("404") then
        notify("⚠️ Isi Salah", "Bukan data ruangan")
        print("ISI DITERIMA: "..isi)
        return
    end

    isi = isi:gsub("^%s+", ""):gsub("%s+$", ""):gsub("[\r\n]+", "")

    local placeIdStr, jobIdStr = isi:match("^(%d+),(.+)$")
    local placeId = tonumber(placeIdStr)
    if not placeId or not jobIdStr or jobIdStr == "" then
        notify("❌ Format Salah", "Harus: angka,kode")
        return
    end

    -- Kalau sudah di ruangan yang benar, jangan pindah lagi sama sekali
    if game.PlaceId == placeId and game.JobId == jobIdStr then
        notify("✅ Sudah Masuk", "Di ruangan yang benar")
        return
    end

    notify("🔄 Coba Masuk", "Ke: "..placeId)
    -- ✅ TAMBAHAN: Cegah kotak paksa + tangani jika penuh
    local okPindah, err = pcall(function()
        return TeleportService:TeleportToPlaceInstance(placeId, jobIdStr, LocalPlayer)
    end)

    if not okPindah then
        -- Deteksi kalau alasannya penuh
        if err:lower():find("full") or err:lower():find("penuh") then
            notify("⏳ Server Penuh", "Menunggu 20 detik lalu coba lagi...")
            -- ✅ Jeda lebih lama saat penuh supaya tidak muncul pesan terus
            task.wait(20)
        else
            notify("❌ Gagal Pindah", tostring(err))
        end
    end
end

task.spawn(function()
    notify("🔍 Pantau", "Baca setiap 10 detik")
    while task.wait(10) do
        cekDanGabung()
    end
end)
