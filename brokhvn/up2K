-- Spektator
local function stopSpectate()
	isSpectating = false
	Camera.CameraSubject = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
	btnSpek.Text = "Spek"
	btnSpek.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
end

local function startSpectate()
	if not selectedPlayer then return end
	local hum = selectedPlayer.Character and selectedPlayer.Character:FindFirstChild("Humanoid")
	if hum then
		isSpectating = true
		Camera.CameraSubject = hum
		btnSpek.Text = "Stop"
		btnSpek.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
	end
end

btnSpek.MouseButton1Click:Connect(function()
	if isSpectating then stopSpectate() else startSpectate() end
end)

-- Startup
btnStartup.MouseButton1Click:Connect(function()
	if surBeanProp and surBeanProp.Parent and surSignProp and surSignProp.Parent then
		StarterGui:SetCore("ChatMakeSystemMessage", {
			Text = "Props sudah ada, tidak perlu spawn ulang.",
			Color = Color3.fromRGB(255, 200, 100)
		})
		return
	end

	btnStartup.Text = "Wait..."
	btnStartup.BackgroundColor3 = Color3.fromRGB(100, 100, 20)

	task.spawn(function()
		local RE = ReplicatedStorage:WaitForChild("RE")
		local tool, toolRemote, spawnPart, hrp = getPropMakerReady()
		if not tool then
			btnStartup.Text = "Startup"
			btnStartup.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
			return
		end

		local base = hrp.Position + hrp.CFrame.LookVector * 4
		local tc = getTrafficCones()

		-- Spawn GirlyBeanBagPink jika belum ada
		if not surBeanProp or not surBeanProp.Parent then
			RE["1Clea1rTool1s"]:FireServer("RequestingPropName", "GirlyBeanBagPink", "Girly", "Home")
			task.wait(0.5)
			local beanBefore = 0
			if tc then
				for _, o in ipairs(tc:GetChildren()) do
					if o.Name == "Prop"..LocalPlayer.Name and not isSignProp(o) then beanBefore += 1 end
				end
			end
			pcall(function() toolRemote:FireServer(spawnPart, base) end)
			task.wait(2)
			if tc then
				local cnt = 0
				for _, o in ipairs(tc:GetChildren()) do
					if o.Name == "Prop"..LocalPlayer.Name and not isSignProp(o) then
						cnt += 1
						if cnt > beanBefore then surBeanProp = o; break end
					end
				end
			end
		end

		-- Spawn SignWhiteBig jika belum ada
		if not surSignProp or not surSignProp.Parent then
			RE["1Clea1rTool1s"]:FireServer("RequestingPropName", "SignWhiteBig", "Sign", "Work")
			task.wait(0.5)
			local signBefore = 0
			if tc then
				for _, o in ipairs(tc:GetChildren()) do
					if o.Name == "Prop"..LocalPlayer.Name and isSignProp(o) then signBefore += 1 end
				end
			end
			pcall(function() toolRemote:FireServer(spawnPart, base + Vector3.new(2,0,0)) end)
			task.wait(2)
			if tc then
				local cnt = 0
				for _, o in ipairs(tc:GetChildren()) do
					if o.Name == "Prop"..LocalPlayer.Name and isSignProp(o) then
						cnt += 1
						if cnt > signBefore then surSignProp = o; break end
					end
				end
			end
		end

		if surBeanProp and surBeanProp.Parent and surSignProp and surSignProp.Parent then
			btnStartup.Text = "Startup ✔"
			btnStartup.BackgroundColor3 = Color3.fromRGB(30, 100, 60)
			StarterGui:SetCore("ChatMakeSystemMessage", {
				Text = "Startup selesai, props siap digunakan.",
				Color = Color3.fromRGB(100, 255, 100)
			})
		else
			btnStartup.Text = "Startup"
			btnStartup.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
			StarterGui:SetCore("ChatMakeSystemMessage", {
				Text = "Gagal spawn props.",
				Color = Color3.fromRGB(255, 100, 100)
			})
		end
	end)
end)

-- Suprise (Start/Stop)
local function stopSupriseLoop()
	if surConn then
		surConn:Disconnect()
		surConn = nil
	end
	surRunning = false
	btnSuprise.Text = "Suprise"
	btnSuprise.BackgroundColor3 = Color3.fromRGB(70, 40, 90)
end

local function startSupriseLoop()
	if not selectedPlayer then
		StarterGui:SetCore("ChatMakeSystemMessage", {
			Text = "Pilih player dulu!",
			Color = Color3.fromRGB(255, 150, 50)
		})
		return
	end
	if not surBeanProp or not surBeanProp.Parent or not surSignProp or not surSignProp.Parent then
		StarterGui:SetCore("ChatMakeSystemMessage", {
			Text = "Props belum ada, lakukan Startup dulu.",
			Color = Color3.fromRGB(255, 150, 50)
		})
		return
	end

	surRunning = true
	btnSuprise.Text = "Stop"
	btnSuprise.BackgroundColor3 = Color3.fromRGB(200, 60, 60)

	-- Posisikan SignWhiteBig di atas player local (statis)
	local hrp = getHRP()
	if hrp then
		local signPos = hrp.Position + Vector3.new(0, HEIGHT_ABOVE, 0)
		pcall(function() surSignProp.SetCurrentCFrame:InvokeServer(CFrame.new(signPos)) end)
	end

	surConn = RunService.Heartbeat:Connect(function()
		if not surBeanProp or not surBeanProp.Parent then
			stopSupriseLoop()
			return
		end
		if not selectedPlayer or not selectedPlayer.Parent then
			stopSupriseLoop()
			return
		end

		local targetChar = selectedPlayer.Character
		local targetHum = targetChar and targetChar:FindFirstChild("Humanoid")
		local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
		if not targetHum or not targetHRP then return end

		if targetHum.Sit then
			-- Teleport bean bag ke bawah sign (5 stud di bawah)
			local myHRP = getHRP()
			if myHRP then
				local finalPos = myHRP.Position + Vector3.new(0, HEIGHT_ABOVE - 5, 0)
				pcall(function() surBeanProp.SetCurrentCFrame:InvokeServer(CFrame.new(finalPos)) end)
			end
			stopSupriseLoop()
		else
			-- Oscillate di atas target
			local offsetY = 0.5 + 1.5 * math.sin(tick() * 35)
			local pos = targetHRP.Position + Vector3.new(0, offsetY, 0)
			pcall(function() surBeanProp.SetCurrentCFrame:InvokeServer(CFrame.new(pos)) end)
		end
	end)
end

btnSuprise.MouseButton1Click:Connect(function()
	if surRunning then
		stopSupriseLoop()
	else
		startSupriseLoop()
	end
end)

-- Change Text (pindahkan SignWhiteBig ke depan player)
btnChangeText.MouseButton1Click:Connect(function()
	if not surSignProp or not surSignProp.Parent then
		StarterGui:SetCore("ChatMakeSystemMessage", {
			Text = "SignWhiteBig belum ada, lakukan Startup dulu.",
			Color = Color3.fromRGB(255, 150, 50)
		})
		return
	end
	local hrp = getHRP()
	if hrp then
		local frontPos = hrp.Position + hrp.CFrame.LookVector * SIGN_FRONT_DIST
		pcall(function() surSignProp.SetCurrentCFrame:InvokeServer(CFrame.new(frontPos)) end)
	end
end)

