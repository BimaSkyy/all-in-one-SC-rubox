-- ═══ LIGHT ORBIT (13x LightsBlinkingColor ngorbit papan, ngikutin kemanapun papan pindah) ═══
local function stopLightOrbit()
	lightOrbitRunning = false
end

local function startLightOrbit()
	if lightOrbitRunning then return end
	if not surSignProp or not surSignProp.Parent then return end
	if #surLights == 0 then return end

	lightOrbitRunning = true
	print("[CompactToolbox] Light orbit dimulai, jumlah lampu: " .. #surLights)

	task.spawn(function()
		local interval = 1 / ORBIT_UPDATE_HZ
		while lightOrbitRunning do
			if not surSignProp or not surSignProp.Parent then
				warn("[CompactToolbox] Papan hilang, orbit dihentikan.")
				stopLightOrbit()
				break
			end

			-- Ambil posisi PAPAN SAAT INI (live), jadi kalau papan pindah/gerak, lampu otomatis ikut
			local signPos = getPropPosition(surSignProp)
			if not signPos then
				warn("[CompactToolbox] Gagal baca posisi papan (getPropPosition nil), skip tick ini.")
				task.wait(interval)
			else
				local t = tick()
				for i, light in ipairs(surLights) do
					if light and light.Parent then
						local angle = (i / LIGHT_COUNT) * (2 * math.pi) + t * ORBIT_SPEED
						local outward = Vector3.new(math.cos(angle), 0, math.sin(angle))   -- arah menjauh dari papan
						local tangent = Vector3.new(-math.sin(angle), 0, math.cos(angle))  -- sumbu buat miringin

						local pos = signPos + outward * ORBIT_RADIUS
						-- Miring 45° menjauhi papan: yang di belakang miring ke belakang, yang di kiri miring ke kiri, dst
						local cf = CFrame.new(pos) * CFrame.fromAxisAngle(tangent, -LIGHT_TILT_ANGLE)

						local remote = getSetCFrameRemote(light)
						if remote then
							-- Fire & forget (task.spawn) supaya InvokeServer yang lambat/nge-lag gak nge-block loop -> orbit jadi smooth
							task.spawn(function()
								local ok, err = pcall(function() remote:InvokeServer(cf) end)
								if not ok then
									warn("[CompactToolbox] Lampu #" .. i .. " gagal di-invoke: " .. tostring(err))
								end
							end)
						else
							warn("[CompactToolbox] Lampu #" .. i .. " gak ketemu remote SetCurrentCFrame-nya.")
						end
					end
				end
				task.wait(interval)
			end
		end
	end)
end

-- Startup
btnStartup.MouseButton1Click:Connect(function()
	local lightsComplete = #surLights >= LIGHT_COUNT
	if surBeanProp and surBeanProp.Parent and surSignProp and surSignProp.Parent and lightsComplete then
		StarterGui:SetCore("ChatMakeSystemMessage", {
			Text = "Props sudah ada, tidak perlu spawn ulang.",
			Color = Color3.fromRGB(255, 200, 100)
		})
		if not lightOrbitRunning then startLightOrbit() end
		return
	end

	btnStartup.Text = "Wait..."
	btnStartup.BackgroundColor3 = Color3.fromRGB(100, 100, 20)

	task.spawn(function()
		local tool, toolRemote, spawnPart, hrp = getPropMakerReady()
		if not tool then
			btnStartup.Text = "Startup"
			btnStartup.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
			return
		end

		local base = hrp.Position + hrp.CFrame.LookVector * 4

		-- 1) Bangku (GirlyBeanBagPink)
		if not surBeanProp or not surBeanProp.Parent then
			surBeanProp = spawnGenericProp(toolRemote, spawnPart, "GirlyBeanBagPink", "Girly", "Home", base)
		end

		-- 2) Papan (SignWhiteBig) -> langsung ditaruh diam di HEIGHT_ABOVE
		if not surSignProp or not surSignProp.Parent then
			surSignProp = spawnGenericProp(toolRemote, spawnPart, "SignWhiteBig", "Sign", "Work", base + Vector3.new(2, 0, 0))
			if surSignProp then
				surSignPos = hrp.Position + Vector3.new(0, HEIGHT_ABOVE, 0)
				pcall(function() surSignProp.SetCurrentCFrame:InvokeServer(CFrame.new(surSignPos)) end)
			end
		end

		-- 3) 13x LightsBlinkingColor, nanti orbit ngelilingin papan
		if surSignProp and surSignProp.Parent then
			for i = #surLights + 1, LIGHT_COUNT do
				local tempPos = base + Vector3.new(i * 0.5, 0, 0)
				local light = spawnGenericProp(toolRemote, spawnPart, "LightsBlinkingColor", "Lights", "Home", tempPos)
				if light then
					table.insert(surLights, light)
				else
					warn("[CompactToolbox] Gagal spawn LightsBlinkingColor #" .. i)
				end
				task.wait(0.2)
			end
		end

		local allReady = surBeanProp and surBeanProp.Parent and surSignProp and surSignProp.Parent and #surLights >= LIGHT_COUNT
		if allReady then
			btnStartup.Text = "Startup ✔"
			btnStartup.BackgroundColor3 = Color3.fromRGB(30, 100, 60)
			StarterGui:SetCore("ChatMakeSystemMessage", {
				Text = "Startup selesai: papan, bangku, dan " .. #surLights .. "/" .. LIGHT_COUNT .. " lights siap.",
				Color = Color3.fromRGB(100, 255, 100)
			})
			startLightOrbit()
		else
			btnStartup.Text = "Startup"
			btnStartup.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
			StarterGui:SetCore("ChatMakeSystemMessage", {
				Text = "Startup belum lengkap (" .. #surLights .. "/" .. LIGHT_COUNT .. " lights).",
				Color = Color3.fromRGB(255, 150, 100)
			})
		end
	end)
end)

-- Suprise (Start/Stop)
local function stopSupriseLoop()
	if surConn then
		surConn:Disconnect()
		surConn = nil
	end
	surRunning = false
	btnSuprise.Text = "Suprise"
	btnSuprise.BackgroundColor3 = Color3.fromRGB(70, 40, 90)
end

local function startSupriseLoop()
	if not selectedPlayer then
		StarterGui:SetCore("ChatMakeSystemMessage", {
			Text = "Pilih player dulu!",
			Color = Color3.fromRGB(255, 150, 50)
		})
		return
	end
	if not surBeanProp or not surBeanProp.Parent or not surSignProp or not surSignProp.Parent then
		StarterGui:SetCore("ChatMakeSystemMessage", {
			Text = "Props belum ada, lakukan Startup dulu.",
			Color = Color3.fromRGB(255, 150, 50)
		})
		return
	end

	surRunning = true
	btnSuprise.Text = "Stop"
	btnSuprise.BackgroundColor3 = Color3.fromRGB(200, 60, 60)

	local hrp = getHRP()
	if hrp then
		local signPos = hrp.Position + Vector3.new(0, HEIGHT_ABOVE, 0)
		pcall(function() surSignProp.SetCurrentCFrame:InvokeServer(CFrame.new(signPos)) end)
	end

	surConn = RunService.Heartbeat:Connect(function()
		if not surBeanProp or not surBeanProp.Parent then
			stopSupriseLoop()
			return
		end
		if not selectedPlayer or not selectedPlayer.Parent then
			stopSupriseLoop()
			return
		end

		local targetChar = selectedPlayer.Character
		local targetHum = targetChar and targetChar:FindFirstChild("Humanoid")
		local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
		if not targetHum or not targetHRP then return end

		if targetHum.Sit then
			local myHRP = getHRP()
			if myHRP then
				local finalPos = myHRP.Position + Vector3.new(0, HEIGHT_ABOVE - 5, 0)
				pcall(function() surBeanProp.SetCurrentCFrame:InvokeServer(CFrame.new(finalPos)) end)
			end
			stopSupriseLoop()
		else
			local offsetY = 0.5 + 1.5 * math.sin(tick() * 35)
			local pos = targetHRP.Position + Vector3.new(0, offsetY, 0)
			pcall(function() surBeanProp.SetCurrentCFrame:InvokeServer(CFrame.new(pos)) end)
		end
	end)
end

btnSuprise.MouseButton1Click:Connect(function()
	if surRunning then
		stopSupriseLoop()
	else
		startSupriseLoop()
	end
end)

