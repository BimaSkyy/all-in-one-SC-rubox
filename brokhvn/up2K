-- ═══ HELPERS ═══
local function getTrafficCones()
	local wsCom = workspace:FindFirstChild("WorkspaceCom")
	return wsCom and wsCom:FindFirstChild("001_TrafficCones")
end

local function isSignProp(prop)
	local clicky = prop:FindFirstChild("Clicky")
	if not clicky then return false end
	local sign3 = clicky:FindFirstChild("Sign3")
	if not sign3 then return false end
	return sign3:FindFirstChild("BoardNumberString") ~= nil
end

local function getSignId(prop)
	local clicky = prop:FindFirstChild("Clicky")
	if not clicky then return nil end
	local sign3 = clicky:FindFirstChild("Sign3")
	if not sign3 then return nil end
	local bns = sign3:FindFirstChild("BoardNumberString")
	if not bns then return nil end
	return bns.Value
end

local function getHRP()
	return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

local function getSpawnPart()
	local model = workspace:FindFirstChild("Model")
	if not model then return nil end
	local s1 = model:FindFirstChild("Street")
	if not s1 then return nil end
	return s1:FindFirstChild("Street")
end

-- Siapkan PropMaker + spawnPart, return tool, toolRemote, spawnPart
local function getPropMakerReady()
	local RE = ReplicatedStorage:WaitForChild("RE")
	local tool = LocalPlayer.Character:FindFirstChild("PropMaker")
		or LocalPlayer.Backpack:FindFirstChild("PropMaker")
	if not tool then
		RE["1Too1l"]:InvokeServer("PickingTools", "PropMaker")
		task.wait(0.8)
		tool = LocalPlayer.Character:FindFirstChild("PropMaker")
			or LocalPlayer.Backpack:FindFirstChild("PropMaker")
	end
	if not tool or not tool:IsA("Tool") then
		return nil
	end
	local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if not hum then return nil end
	hum:EquipTool(tool)
	task.wait(0.3)

	pcall(function() RE["1Clea1rTool1s"]:FireServer("ClosePropMenu") end)
	task.wait(0.15)

	local hrp = getHRP()
	if not hrp then return nil end

	local spawnPart = getSpawnPart()
	if not spawnPart then
		local ray = workspace:Raycast(hrp.Position, Vector3.new(0, -20, 0))
		if ray and ray.Instance then spawnPart = ray.Instance end
	end
	if not spawnPart then return nil end

	local toolRemote = tool:WaitForChild("Tool_PropMake", 10)
	if not toolRemote then return nil end

	return tool, toolRemote, spawnPart, hrp
end

-- Snapshot semua prop milik LocalPlayer di TrafficCones (dipakai buat deteksi prop baru)
local function getMyProps()
	local tc = getTrafficCones()
	local set = {}
	if tc then
		for _, o in ipairs(tc:GetChildren()) do
			if o.Name == "Prop"..LocalPlayer.Name then
				set[o] = true
			end
		end
	end
	return set
end

local function findNewProp(before)
	local tc = getTrafficCones()
	if not tc then return nil end
	for _, o in ipairs(tc:GetChildren()) do
		if o.Name == "Prop"..LocalPlayer.Name and not before[o] then
			return o
		end
	end
	return nil
end

-- Baca posisi LIVE sebuah prop (Model/BasePart), dipakai biar orbit selalu ngikutin papan kemanapun dia pindah/gerak
local function getPropPosition(prop)
	if not prop or not prop.Parent then return nil end
	if prop:IsA("Model") then
		local ok, pivot = pcall(function() return prop:GetPivot() end)
		if ok and pivot then return pivot.Position end
		if prop.PrimaryPart then return prop.PrimaryPart.Position end
	elseif prop:IsA("BasePart") then
		return prop.Position
	end
	local part = prop:FindFirstChildWhichIsA("BasePart", true)
	if part then return part.Position end
	return nil
end

-- Cari RemoteFunction "SetCurrentCFrame" di prop. Dicari langsung dulu, kalau gak ada cari ke descendant
-- (jaga-jaga kalau struktur LightsBlinkingColor beda dari papan/bangku)
local function getSetCFrameRemote(prop)
	if not prop then return nil end
	local direct = prop:FindFirstChild("SetCurrentCFrame")
	if direct then return direct end
	return prop:FindFirstChild("SetCurrentCFrame", true)
end

-- Spawn 1 prop generik via RequestingPropName + Tool_PropMake, return instance prop barunya (atau nil)
local function spawnGenericProp(toolRemote, spawnPart, propName, category1, category2, pos)
	local RE = ReplicatedStorage:WaitForChild("RE")
	local before = getMyProps()

	RE["1Clea1rTool1s"]:FireServer("RequestingPropName", propName, category1, category2)
	task.wait(0.5)

	pcall(function() toolRemote:FireServer(spawnPart, pos) end)
	task.wait(1.2)

	return findNewProp(before)
end

