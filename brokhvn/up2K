local playerButtons = {}
local function refreshPlayerList()
	for _, b in ipairs(playerButtons) do b:Destroy() end
	playerButtons = {}
	local y = 2
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			local btn = Instance.new("TextButton", plistScrolling)
			btn.Size = UDim2.new(1, -4, 0, 20)
			btn.Position = UDim2.new(0, 2, 0, y)
			btn.BackgroundColor3 = (selectedPlayer == plr) and Color3.fromRGB(70, 70, 120) or Color3.fromRGB(35, 35, 55)
			btn.Text = plr.Name
			btn.TextColor3 = Color3.new(1,1,1)
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 9
			btn.AutoButtonColor = false
			btn.ZIndex = 3
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)
			btn.MouseButton1Click:Connect(function()
				selectedPlayer = (selectedPlayer == plr) and nil or plr
				refreshPlayerList()
			end)
			table.insert(playerButtons, btn)
			y = y + 22
		end
	end
	plistScrolling.CanvasSize = UDim2.new(0, 0, 0, y + 2)
end

Players.PlayerAdded:Connect(refreshPlayerList)
Players.PlayerRemoving:Connect(function(plr)
	if selectedPlayer == plr then
		selectedPlayer = nil
		if isSpectating then stopSpectate() end
	end
	refreshPlayerList()
end)

