-- ═══ INPUT HANDLER ═══
local function onAdminInputBegan(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType ~= Enum.UserInputType.Touch and input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

    local ray = Camera:ScreenPointToRay(input.Position.X, input.Position.Y)
    local hit = Workspace:Raycast(ray.Origin, ray.Direction * 500)
    if hit then
        local char = hit.Instance:FindFirstAncestorOfClass("Model")
        if char then
            local plr = Players:GetPlayerFromCharacter(char)
            if plr and plr ~= LocalPlayer then
                createAdminGuiForTarget(plr)
            end
        end
    end
end

-- ═══ TOOL: ADMIN JAIL ═══
local function createAdminTool()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    if backpack:FindFirstChild(ADMIN_TOOL_NAME) then return end

    adminTool = Instance.new("Tool")
    adminTool.Name = ADMIN_TOOL_NAME
    adminTool.RequiresHandle = false
    adminTool.CanBeDropped = false
    adminTool.ToolTip = "Klik player untuk Jail/Spectator"

    adminTool.Equipped:Connect(function()
        touchConn = UserInputService.InputBegan:Connect(onAdminInputBegan)
        if jailTarget then
            destroyAntenna()
            createAdminGuiForTarget(jailTarget)
        end
    end)

    adminTool.Unequipped:Connect(function()
        if touchConn then touchConn:Disconnect(); touchConn = nil end
        destroyAdminGui()
        if jailTarget and jailActive then
            createAntenna(jailTarget)
        end
        stopSpectate()
    end)

    adminTool.Parent = backpack
end

