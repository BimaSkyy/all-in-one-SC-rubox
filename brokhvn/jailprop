    txtInput.Position = UDim2.new(0, 10, 0, 85)
    txtInput.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    txtInput.TextColor3 = Color3.new(1, 1, 1)
    txtInput.Font = Enum.Font.Gotham
    txtInput.TextSize = 12
    txtInput.PlaceholderText = "Masukkan teks..."
    if customJailText then txtInput.Text = customJailText end

    local btnSet = Instance.new("TextButton", frame)
    btnSet.Size = UDim2.new(0, 80, 0, 25)
    btnSet.Position = UDim2.new(0, 10, 0, 115)
    btnSet.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    btnSet.Text = "Set"
    btnSet.TextColor3 = Color3.new(1, 1, 1)
    btnSet.Font = Enum.Font.GothamBold
    btnSet.TextSize = 12
    Instance.new("UICorner", btnSet).CornerRadius = UDim.new(0, 4)
    btnSet.MouseButton1Click:Connect(function()
        customJailText = txtInput.Text
        print("[Setup] Custom text set to:", customJailText)
    end)

    local btnReset = Instance.new("TextButton", frame)
    btnReset.Size = UDim2.new(0, 80, 0, 25)
    btnReset.Position = UDim2.new(0, 100, 0, 115)
    btnReset.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    btnReset.Text = "Reset"
    btnReset.TextColor3 = Color3.new(1, 1, 1)
    btnReset.Font = Enum.Font.GothamBold
    btnReset.TextSize = 12
    Instance.new("UICorner", btnReset).CornerRadius = UDim.new(0, 4)
    btnReset.MouseButton1Click:Connect(function()
        customJailText = nil
        txtInput.Text = ""
        print("[Setup] Custom text reset to default.")
    end)

    return sg
end

-- ═══ TOOL: SETUP ═══
local function createSetupTool()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    if backpack:FindFirstChild(SETUP_TOOL_NAME) then return end

    setupTool = Instance.new("Tool")
    setupTool.Name = SETUP_TOOL_NAME
    setupTool.RequiresHandle = false
    setupTool.CanBeDropped = false
    setupTool.ToolTip = "Setup props & custom text"

    local setupGui = nil
    setupTool.Equipped:Connect(function()
        setupGui = createSetupGui()
    end)
    setupTool.Unequipped:Connect(function()
        if setupGui then setupGui:Destroy(); setupGui = nil end
    end)
    setupTool.Parent = backpack
end

