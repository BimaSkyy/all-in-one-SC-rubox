-- ═══ HELPERS ═══
local function getTrafficCones()
    local wsCom = Workspace:FindFirstChild("WorkspaceCom")
    return wsCom and wsCom:FindFirstChild("001_TrafficCones")
end

local function getSpawnPart()
    local model = Workspace:FindFirstChild("Model")
    if not model then return nil end
    local s1 = model:FindFirstChild("Street")
    if not s1 then return nil end
    return s1:FindFirstChild("Street")
end

local function getPropMakerReady()
    local tool2 = LocalPlayer.Character:FindFirstChild("PropMaker") 
        or LocalPlayer.Backpack:FindFirstChild("PropMaker")
    if not tool2 then
        RE["1Too1l"]:InvokeServer("PickingTools", "PropMaker")
        task.wait(0.8)
        tool2 = LocalPlayer.Character:FindFirstChild("PropMaker") 
            or LocalPlayer.Backpack:FindFirstChild("PropMaker")
    end
    if not tool2 or not tool2:IsA("Tool") then return nil end
    local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    hum:EquipTool(tool2)
    task.wait(0.3)
    pcall(function() RE["1Clea1rTool1s"]:FireServer("ClosePropMenu") end)
    task.wait(0.15)
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local spawnPart = getSpawnPart()
    if not spawnPart then
        local ray = Workspace:Raycast(hrp.Position, Vector3.new(0, -20, 0))
        if ray and ray.Instance then spawnPart = ray.Instance end
    end
    if not spawnPart then return nil end
    local toolRemote = tool2:WaitForChild("Tool_PropMake", 10)
    if not toolRemote then return nil end
    return tool2, toolRemote, spawnPart, hrp
end

local function spawnGenericProp(toolRemote, spawnPart, propName, category1, category2, pos)
    local tc = getTrafficCones()
    local before = {}
    if tc then
        for _, o in ipairs(tc:GetChildren()) do
            if o.Name == "Prop"..LocalPlayer.Name then before[o] = true end
        end
    end
    RE["1Clea1rTool1s"]:FireServer("RequestingPropName", propName, category1, category2)
    task.wait(0.5)
    pcall(function() toolRemote:FireServer(spawnPart, pos) end)
    task.wait(1.5)
    if tc then
        for _, o in ipairs(tc:GetChildren()) do
            if o.Name == "Prop"..LocalPlayer.Name and not before[o] then
                return o
            end
        end
    end
    return nil
end

local function getSignId(prop)
    if not prop or not prop.Parent then return nil end
    local touch = prop:FindFirstChild("Touch") or prop:FindFirstChild("Clicky")
    if not touch then return nil end
    local sign2 = touch:FindFirstChild("Sign2")
    if not sign2 then return nil end
    local bns = sign2:FindFirstChild("BoardNumberString")
    return bns and bns.Value or nil
end

local function setSignText(prop, text)
    if not prop or not prop.Parent then return end
    local id = getSignId(prop)
    if not id then return end
    pcall(function()
        RE["1Cemeter1y"]:FireServer("ReturningBigSign2Name", id, text)
    end)
end

-- ═══ SETUP PROPS ═══
local function setupProps()
    if cageProp and cageProp.Parent and fenceProp and fenceProp.Parent 
        and torchProp and torchProp.Parent and signProp and signProp.Parent then
        return true
    end

    local _, toolRemote, spawnPart, hrp = getPropMakerReady()
    if not toolRemote then 
        warn("PropMaker tidak siap") 
        return false 
    end

    local basePos = hrp.Position + hrp.CFrame.LookVector * 4

    torchProp = spawnGenericProp(toolRemote, spawnPart, PROP_TORCH, "Torch", "Decor", basePos)
    signProp  = spawnGenericProp(toolRemote, spawnPart, PROP_SIGN, "Sign", "Work", basePos + Vector3.new(2,0,0))
    fenceProp = spawnGenericProp(toolRemote, spawnPart, PROP_FENCE, "Big", "Home", basePos + Vector3.new(-2,0,0))
    cageProp  = spawnGenericProp(toolRemote, spawnPart, PROP_CAGE, "Big", "Home", basePos + Vector3.new(0,0,2))

    if not cageProp or not fenceProp or not torchProp or not signProp then
        warn("Gagal spawn salah satu prop")
        return false
    end

    task.wait(0.5)
    setSignText(signProp, DEFAULT_SIGN_TEXT)
    return true
end

-- ═══ ANTENA ═══
local function destroyAntenna()
    if antennaUpdateLoop then antennaUpdateLoop:Disconnect(); antennaUpdateLoop = nil end
    if antennaBeam then antennaBeam:Destroy(); antennaBeam = nil end
    if antennaAttach0 then antennaAttach0:Destroy(); antennaAttach0 = nil end
    if antennaAttach1 then antennaAttach1:Destroy(); antennaAttach1 = nil end
    if antennaDistanceGui then antennaDistanceGui:Destroy(); antennaDistanceGui = nil end
    antennaDistanceLabel = nil
end

local function createAntenna(target)
    destroyAntenna()
    local myChar = LocalPlayer.Character
    local targetChar = target and target.Character
    if not myChar or not targetChar then return end
    local myHead = myChar:FindFirstChild("Head")
    local targetHead = targetChar:FindFirstChild("Head")
    if not myHead or not targetHead then return end

    antennaAttach0 = Instance.new("Attachment")
    antennaAttach0.Position = Vector3.new(0, 0.5, 0)
    antennaAttach0.Parent = myHead

    antennaAttach1 = Instance.new("Attachment")
    antennaAttach1.Position = Vector3.new(0, 0.5, 0)
    antennaAttach1.Parent = targetHead

    antennaBeam = Instance.new("Beam")
    antennaBeam.Attachment0 = antennaAttach0
    antennaBeam.Attachment1 = antennaAttach1
    antennaBeam.Width0 = 0.12
    antennaBeam.Width1 = 0.12
    antennaBeam.Color = ColorSequence.new(Color3.fromRGB(0, 255, 0))
    antennaBeam.Transparency = NumberSequence.new(0.6)
    antennaBeam.FaceCamera = true
    antennaBeam.Parent = antennaAttach0

    antennaDistanceGui = Instance.new("BillboardGui")
    antennaDistanceGui.Adornee = targetHead
    antennaDistanceGui.Size = UDim2.new(0, 100, 0, 20)
    antennaDistanceGui.StudsOffset = Vector3.new(0, 2.2, 0)
    antennaDistanceGui.AlwaysOnTop = true
    antennaDistanceGui.Parent = targetHead

    antennaDistanceLabel = Instance.new("TextLabel", antennaDistanceGui)
    antennaDistanceLabel.Size = UDim2.new(1,0,1,0)
    antennaDistanceLabel.BackgroundTransparency = 1
    antennaDistanceLabel.Text = "0 studs"
    antennaDistanceLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    antennaDistanceLabel.Font = Enum.Font.GothamBold
    antennaDistanceLabel.TextSize = 13
    antennaDistanceLabel.TextStrokeTransparency = 0.5

    antennaUpdateLoop = RunService.Heartbeat:Connect(function()
        if not antennaAttach0 or not antennaAttach0.Parent 
            or not antennaAttach1 or not antennaAttach1.Parent then
            destroyAntenna()
            return
        end
        local dist = (antennaAttach0.WorldPosition - antennaAttach1.WorldPosition).Magnitude
        if antennaDistanceLabel then
            antennaDistanceLabel.Text = string.format("%.1f studs", dist)
        end
    end)
end

-- ═══ MOVE PROPS (DIPERBARUI UNTUK SEMUA PROP) ═══
local function movePropsToCFrame(cframe)
    local function moveSingle(prop, offsetCF)
        if prop and prop.Parent then
            local remote = prop:FindFirstChild("SetCurrentCFrame") 
                or prop:FindFirstChild("SetCurrentCFrame", true)
            if remote then
                pcall(function() 
                    remote:InvokeServer(cframe * offsetCF) 
                end)
            end
        end
    end

    -- 4 prop utama dengan offset spesial
    moveSingle(cageProp, OFFSET_CAGE)
    moveSingle(fenceProp, OFFSET_FENCE)
    moveSingle(torchProp, OFFSET_TORCH)
    moveSingle(signProp, OFFSET_SIGN)

    -- Semua prop lain milik local player
    local tc = getTrafficCones()
    if tc then
        for _, obj in ipairs(tc:GetChildren()) do
            if obj.Name == "Prop"..LocalPlayer.Name 
                and obj ~= cageProp 
                and obj ~= fenceProp 
                and obj ~= torchProp 
                and obj ~= signProp then
                moveSingle(obj, DEFAULT_PROP_OFFSET) -- di bawah kaki target
            end
        end
    end
end

local function movePropsToTarget(targetHRP)
    movePropsToCFrame(targetHRP.CFrame)
end

local function movePropsToSky()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        movePropsToCFrame(CFrame.new(hrp.Position + SKY_OFFSET))
    else
        movePropsToCFrame(CFrame.new(0, 10000, 0))
    end
end

-- ═══ JAIL CONTROL ═══
local function stopJail()
    jailTimerActive = false
    if jailTimerThread then
        task.cancel(jailTimerThread)
        jailTimerThread = nil
    end
    if jailHeartbeat then
        jailHeartbeat:Disconnect()
        jailHeartbeat = nil
    end
    movePropsToSky()
    jailActive = false
    jailTarget = nil
    destroyAntenna()
end

local function startJail(target)
    if not target or not target.Character then return end
    stopJail()
    jailTarget = target
    jailActive = true

    local textToSet
    if customJailText and customJailText ~= "" then
        textToSet = customJailText
    else
        textToSet = DEFAULT_SIGN_TEXT
    end
    if signProp then setSignText(signProp, textToSet) end

    jailHeartbeat = RunService.Heartbeat:Connect(function()
        if not jailTarget or not jailTarget.Parent then
            stopJail()
            return
        end
        local targetChar = jailTarget.Character
        local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHRP then
            movePropsToSky()
            return
        end
        movePropsToTarget(targetHRP)
    end)
end

local function updateTimedJailText()
    if not jailTimerActive or not jailTarget then return end
    local remaining = math.max(0, jailTimerEnd - os.time())
    local minutes = math.floor(remaining / 60)
    local seconds = remaining % 60
    local text = "This Player Was Jailed Timer: " .. string.format("%d:%02d", minutes, seconds)
    if signProp then setSignText(signProp, text) end
    if remaining <= 0 then stopJail() end
end

local function startTimedJail(target)
    if not target or not target.Character then return end
    stopJail()
    startJail(target)

    jailTimerActive = true
    jailTimerEnd = os.time() + 90

    updateTimedJailText()

    local lastUpdate = os.time()
    jailTimerThread = task.spawn(function()
        while jailTimerActive and jailTarget == target do
            task.wait(0.5)
            if not jailTimerActive or jailTarget ~= target then break end
            if os.time() - lastUpdate >= 10 then
                lastUpdate = os.time()
                updateTimedJailText()
            end
            if not jailTimerActive then break end
        end
    end)
end

-- ═══ SPECTATOR ═══
local function startSpectate(target)
    if spectating then stopSpectate() end
    if not target or not target.Character then return end
    local hum = target.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    spectating = true
    spectateTarget = target
    Camera.CameraSubject = hum
end

local function stopSpectate()
    if not spectating then return end
    spectating = false
    local myHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if myHum then Camera.CameraSubject = myHum end
    spectateTarget = nil
end

