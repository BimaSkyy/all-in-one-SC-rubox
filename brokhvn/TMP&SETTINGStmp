        updateLoop:Disconnect()
        updateLoop = nil
    end
    stopSpectate()
    if jailFrame then
        jailFrame:Destroy()
        jailFrame = nil
        jailBtn = nil
        tempelBtn = nil
        teleportBtn = nil
        spekBtn = nil
        nameLabel = nil
    end
    local gui = PlayerGui:FindFirstChild("PMTJailGui")
    if gui then gui:Destroy() end

    if espHighlight then
        espHighlight:Destroy()
        espHighlight = nil
    end

    currentTarget = nil
end

local function showJailGuiForPlayer(targetPlayer)
    destroyJailGui()

    currentTarget = targetPlayer
    createJailGui()
    nameLabel.Text = targetPlayer.Name

    -- Update tampilan tombol sesuai state
    if magnetRunning and magnetTarget == targetPlayer then
        jailBtn.Text = "Jailing..."
        jailBtn.BackgroundColor3 = Color3.fromRGB(230, 50, 50)
    else
        jailBtn.Text = "Jail"
        jailBtn.BackgroundColor3 = Color3.fromRGB(30, 200, 30)
    end

    if stickMode then
        tempelBtn.Text = "Tempel: ON"
        tempelBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        tempelBtn.Text = "Tempel: OFF"
        tempelBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
    end

    if spectating and spectateTarget == targetPlayer then
        spekBtn.Text = "Stop Spek"
        spekBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    else
        spekBtn.Text = "Spek"
        spekBtn.BackgroundColor3 = Color3.fromRGB(30, 100, 200)
    end

    if targetPlayer.Character then
        espHighlight = Instance.new("Highlight")
        espHighlight.Name = "PMTEsp"
        espHighlight.FillColor = Color3.fromRGB(0, 255, 0)
        espHighlight.OutlineColor = Color3.fromRGB(0, 255, 0)
        espHighlight.FillTransparency = 0.5
        espHighlight.OutlineTransparency = 0
        espHighlight.Adornee = targetPlayer.Character
        espHighlight.Parent = targetPlayer.Character
    end

    updateLoop = RunService.RenderStepped:Connect(function()
        if not currentTarget or not currentTarget.Character then
            destroyJailGui()
            return
        end
        local head = currentTarget.Character:FindFirstChild("Head")
        if not head then
            destroyJailGui()
            return
        end
        local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position + Vector3.new(0, 2, 0))
        if not onScreen then
            if jailFrame then jailFrame.Visible = false end
            return
        end
        if jailFrame then
            jailFrame.Visible = true
            jailFrame.Position = UDim2.new(0, screenPos.X, 0, screenPos.Y)
        end
    end)
end

-- ═══ INPUT HANDLER (hanya aktif saat tool PMT dipegang) ═══
local function onInputBegan(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType ~= Enum.UserInputType.Touch and input.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    local ray = Camera:ScreenPointToRay(input.Position.X, input.Position.Y)
    local hit = Workspace:Raycast(ray.Origin, ray.Direction * 500)

    if hit then
        local targetChar = hit.Instance:FindFirstAncestorOfClass("Model")
        if targetChar then
            local targetPlayer = Players:GetPlayerFromCharacter(targetChar)
            if targetPlayer and targetPlayer ~= LocalPlayer then
                showJailGuiForPlayer(targetPlayer)
            end
        end
    end
end

-- ═══ TOOL: PMT ═══
local function createPMTTool()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    if backpack:FindFirstChild(TOOL_NAME) then return end

    tool = Instance.new("Tool")
    tool.Name = TOOL_NAME
    tool.RequiresHandle = false
    tool.CanBeDropped = false
    tool.ToolTip = "Klik player -> Jail / Tempel / Teleport / Spektator"

    tool.Equipped:Connect(function()
        touchConnection = UserInputService.InputBegan:Connect(onInputBegan)
    end)

    tool.Unequipped:Connect(function()
        destroyJailGui()
        stopMagnet()
        stopSpectate()
        if touchConnection then
            touchConnection:Disconnect()
            touchConnection = nil
        end
    end)

    tool.Parent = backpack
end

-- ═══ GUI UNTUK TOOL SETTINGS ═══
local settingsGui = nil

local function createSettingsGui()
    if settingsGui then settingsGui:Destroy() end
    local sg = Instance.new("ScreenGui")
    sg.Name = "PMTSettingsGui"
    sg.Parent = PlayerGui
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0, 220, 0, 150)
    frame.Position = UDim2.new(0.5, -110, 0.5, -75)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, -20, 0, 25)
    title.Position = UDim2.new(0, 10, 0, 5)
    title.BackgroundTransparency = 1
    title.Text = "SETTINGS PMT"
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14
    title.TextColor3 = Color3.new(1, 1, 1)

    -- Teleport Height (digunakan oleh tombol Teleport)
    local lblH = Instance.new("TextLabel", frame)
    lblH.Size = UDim2.new(0, 100, 0, 20)
    lblH.Position = UDim2.new(0, 10, 0, 35)
