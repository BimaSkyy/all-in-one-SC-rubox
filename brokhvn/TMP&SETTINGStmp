-- ═══ HELPERS (Prop System) ═══
local function getTrafficCones()
    local wsCom = Workspace:FindFirstChild("WorkspaceCom")
    return wsCom and wsCom:FindFirstChild("001_TrafficCones")
end

local function getHRP()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

local function getSpawnPart()
    local model = Workspace:FindFirstChild("Model")
    if not model then return nil end
    local s1 = model:FindFirstChild("Street")
    if not s1 then return nil end
    return s1:FindFirstChild("Street")
end

local function getPropMakerReady()
    local RE = ReplicatedStorage:WaitForChild("RE")
    local tool2 = LocalPlayer.Character:FindFirstChild("PropMaker")
        or LocalPlayer.Backpack:FindFirstChild("PropMaker")
    if not tool2 then
        RE["1Too1l"]:InvokeServer("PickingTools", "PropMaker")
        task.wait(0.8)
        tool2 = LocalPlayer.Character:FindFirstChild("PropMaker")
            or LocalPlayer.Backpack:FindFirstChild("PropMaker")
    end
    if not tool2 or not tool2:IsA("Tool") then return nil end
    local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    hum:EquipTool(tool2)
    task.wait(0.3)

    pcall(function() RE["1Clea1rTool1s"]:FireServer("ClosePropMenu") end)
    task.wait(0.15)

    local hrp = getHRP()
    if not hrp then return nil end

    local spawnPart = getSpawnPart()
    if not spawnPart then
        local ray = Workspace:Raycast(hrp.Position, Vector3.new(0, -20, 0))
        if ray and ray.Instance then spawnPart = ray.Instance end
    end
    if not spawnPart then return nil end

    local toolRemote = tool2:WaitForChild("Tool_PropMake", 10)
    if not toolRemote then return nil end

    return tool2, toolRemote, spawnPart, hrp
end

local function getMyPropsSet()
    local tc = getTrafficCones()
    local set = {}
    if tc then
        for _, o in ipairs(tc:GetChildren()) do
            if o.Name == "Prop"..LocalPlayer.Name then
                set[o] = true
            end
        end
    end
    return set
end

local function findNewProp(before)
    local tc = getTrafficCones()
    if not tc then return nil end
    for _, o in ipairs(tc:GetChildren()) do
        if o.Name == "Prop"..LocalPlayer.Name and not before[o] then
            return o
        end
    end
    return nil
end

local function getSetCFrameRemote(prop)
    if not prop then return nil end
    local direct = prop:FindFirstChild("SetCurrentCFrame")
    if direct then return direct end
    return prop:FindFirstChild("SetCurrentCFrame", true)
end

local function spawnGenericProp(toolRemote, spawnPart, propName, category1, category2, pos)
    local RE = ReplicatedStorage:WaitForChild("RE")
    local before = getMyPropsSet()

    RE["1Clea1rTool1s"]:FireServer("RequestingPropName", propName, category1, category2)
    task.wait(0.5)

    pcall(function() toolRemote:FireServer(spawnPart, pos) end)
    task.wait(1.2)

    return findNewProp(before)
end

local function getSeatFromProp(prop)
    if not prop or not prop.Parent then return nil end
    for _, desc in ipairs(prop:GetDescendants()) do
        if desc:IsA("Seat") or desc:IsA("VehicleSeat") then return desc end
    end
    return nil
end

local function generateFibonacciSphere(n)
    local pts = {}
    local offset = 2 / n
    local increment = math.pi * (3 - math.sqrt(5))
    for i = 0, n - 1 do
        local y = ((i * offset) - 1) + (offset / 2)
        local r = math.sqrt(math.max(0, 1 - y * y))
        local phi = i * increment
        local x = math.cos(phi) * r
        local z = math.sin(phi) * r
        table.insert(pts, Vector3.new(x, y, z))
    end
    return pts
end

local function getTeleportOffset(targetHRP)
    local d = teleportHeight
    if teleportDirection == "atas" then
        return Vector3.new(0, d, 0)
    elseif teleportDirection == "bawah" then
        return Vector3.new(0, -d, 0)
    elseif teleportDirection == "kanan" then
        return targetHRP.CFrame.RightVector * d
    elseif teleportDirection == "kiri" then
        return -targetHRP.CFrame.RightVector * d
    elseif teleportDirection == "depan" then
        return targetHRP.CFrame.LookVector * d
    elseif teleportDirection == "belakang" then
        return -targetHRP.CFrame.LookVector * d
    end
    return Vector3.new(0, d, 0)
end

-- ═══ TELEPORT TARGET ═══
local function teleportTarget(target)
    if not target or not target.Character then return end
    local hrp = target.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local offset = getTeleportOffset(hrp)
    local targetPos = hrp.Position + offset

    -- Ganti nama remote di bawah ini sesuai dengan game yang kamu gunakan
    local teleportRemote = ReplicatedStorage:FindFirstChild("TeleportPlayer")
        or (ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("TeleportPlayer"))
    if teleportRemote then
        teleportRemote:FireServer(target, targetPos)
        print("[PMT] Teleport", target.Name, "ke", targetPos)
    else
        warn("[PMT] Remote TeleportPlayer tidak ditemukan. Silakan ganti nama remote yang benar pada script.")
    end
end

