    lblH.Text = "Teleport Height"
    lblH.Font = Enum.Font.Gotham
    lblH.TextSize = 12
    lblH.TextColor3 = Color3.new(0.9, 0.9, 0.9)

    local inputH = Instance.new("TextBox", frame)
    inputH.Size = UDim2.new(0, 80, 0, 20)
    inputH.Position = UDim2.new(0, 120, 0, 35)
    inputH.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    inputH.TextColor3 = Color3.new(1, 1, 1)
    inputH.Font = Enum.Font.Gotham
    inputH.TextSize = 12
    inputH.Text = tostring(teleportHeight)
    inputH.PlaceholderText = "studs"
    inputH.FocusLost:Connect(function()
        local n = tonumber(inputH.Text)
        if n and n >= TELEPORT_HEIGHT_MIN and n <= TELEPORT_HEIGHT_MAX then
            teleportHeight = n
        else
            inputH.Text = tostring(teleportHeight)
        end
    end)

    -- Teleport Direction
    local lblDir = Instance.new("TextLabel", frame)
    lblDir.Size = UDim2.new(0, 100, 0, 20)
    lblDir.Position = UDim2.new(0, 10, 0, 65)
    lblDir.BackgroundTransparency = 1
    lblDir.Text = "Direction"
    lblDir.Font = Enum.Font.Gotham
    lblDir.TextSize = 12
    lblDir.TextColor3 = Color3.new(0.9, 0.9, 0.9)

    local dirIdx = 1
    for i, v in ipairs(directionOrder) do
        if directionMap[v] == teleportDirection then
            dirIdx = i
            break
        end
    end

    local btnDir = Instance.new("TextButton", frame)
    btnDir.Size = UDim2.new(0, 80, 0, 20)
    btnDir.Position = UDim2.new(0, 120, 0, 65)
    btnDir.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btnDir.TextColor3 = Color3.new(1, 1, 1)
    btnDir.Font = Enum.Font.Gotham
    btnDir.TextSize = 12
    btnDir.Text = directionOrder[dirIdx]
    btnDir.AutoButtonColor = false
    btnDir.MouseButton1Click:Connect(function()
        dirIdx = dirIdx % #directionOrder + 1
        local dirName = directionOrder[dirIdx]
        teleportDirection = directionMap[dirName]
        btnDir.Text = dirName
    end)

    -- Magnet Radius
    local lblR = Instance.new("TextLabel", frame)
    lblR.Size = UDim2.new(0, 100, 0, 20)
    lblR.Position = UDim2.new(0, 10, 0, 95)
    lblR.BackgroundTransparency = 1
    lblR.Text = "Magnet Radius"
    lblR.Font = Enum.Font.Gotham
    lblR.TextSize = 12
    lblR.TextColor3 = Color3.new(0.9, 0.9, 0.9)

    local inputR = Instance.new("TextBox", frame)
    inputR.Size = UDim2.new(0, 80, 0, 20)
    inputR.Position = UDim2.new(0, 120, 0, 95)
    inputR.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    inputR.TextColor3 = Color3.new(1, 1, 1)
    inputR.Font = Enum.Font.Gotham
    inputR.TextSize = 12
    inputR.Text = tostring(MAGNET_RADIUS)
    inputR.PlaceholderText = "studs"
    inputR.FocusLost:Connect(function()
        local n = tonumber(inputR.Text)
        if n and n > 0 then
            MAGNET_RADIUS = n
        else
            inputR.Text = tostring(MAGNET_RADIUS)
        end
    end)

    -- Seat Fly Height (digunakan saat target duduk, prop diterbangkan sesuai arah teleport)
    local lblSFH = Instance.new("TextLabel", frame)
    lblSFH.Size = UDim2.new(0, 100, 0, 20)
    lblSFH.Position = UDim2.new(0, 10, 0, 125)
    lblSFH.BackgroundTransparency = 1
    lblSFH.Text = "Seat Fly Height"
    lblSFH.Font = Enum.Font.Gotham
    lblSFH.TextSize = 12
    lblSFH.TextColor3 = Color3.new(0.9, 0.9, 0.9)

    local inputSFH = Instance.new("TextBox", frame)
    inputSFH.Size = UDim2.new(0, 80, 0, 20)
    inputSFH.Position = UDim2.new(0, 120, 0, 125)
    inputSFH.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    inputSFH.TextColor3 = Color3.new(1, 1, 1)
    inputSFH.Font = Enum.Font.Gotham
    inputSFH.TextSize = 12
    inputSFH.Text = tostring(SEAT_FLY_HEIGHT)
    inputSFH.FocusLost:Connect(function()
        local n = tonumber(inputSFH.Text)
        if n and n > 0 then
            SEAT_FLY_HEIGHT = n
        else
            inputSFH.Text = tostring(SEAT_FLY_HEIGHT)
        end
    end)

    settingsGui = sg
end

local function destroySettingsGui()
    if settingsGui then
        settingsGui:Destroy()
        settingsGui = nil
    end
end

-- ═══ TOOL: SETTINGS PMT ═══
local function createSettingsTool()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    if backpack:FindFirstChild(SETTINGS_TOOL_NAME) then return end

    settingsTool = Instance.new("Tool")
    settingsTool.Name = SETTINGS_TOOL_NAME
    settingsTool.RequiresHandle = false
    settingsTool.CanBeDropped = false
    settingsTool.ToolTip = "Atur parameter PMT (teleport, magnet, dll)"

    settingsTool.Equipped:Connect(function()
        createSettingsGui()
    end)

    settingsTool.Unequipped:Connect(function()
        destroySettingsGui()
    end)

    settingsTool.Parent = backpack
end

-- ═══ RESPAWN HANDLER ═══
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    createPMTTool()
    createSettingsTool()
    if magnetRunning and magnetTarget then
        createAntenna(magnetTarget)
        createAntennaDistanceGui(magnetTarget)
    end
    if spectating then
        if spectateTarget and spectateTarget.Character then
            local hum = spectateTarget.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                Camera.CameraSubject = hum
            end
        else
            stopSpectate()
        end
    end
end)

if LocalPlayer.Character then
    createPMTTool()
    createSettingsTool()
end

print("PMT script siap. Gunakan PMT untuk Jail/Tempel/Teleport/Spek, SETTINGS PMT untuk atur parameter.")
