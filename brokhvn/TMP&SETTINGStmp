    nameLabel.TextColor3 = Color3.new(1, 1, 1)
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextSize = 11
    nameLabel.TextStrokeTransparency = 0.5

    jailBtn.MouseButton1Click:Connect(function()
