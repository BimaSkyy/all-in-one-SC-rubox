-- ═══ MAGNET ═══
local function stopMagnet()
    magnetRunning = false
    magnetTarget = nil
    lockedProps = {}
    destroyAntenna()
    destroyAntennaDistanceGui()
    if jailBtn then
        jailBtn.Text = "Jail"
        jailBtn.BackgroundColor3 = Color3.fromRGB(30, 200, 30)
    end
end

local function startMagnetOnTarget(target)
    local tc = getTrafficCones()
    local existing = {}
    if tc then
        for _, o in ipairs(tc:GetChildren()) do
            if o.Name == "Prop"..LocalPlayer.Name then
                table.insert(existing, o)
            end
        end
    end
    pinkChairs = existing

    if #pinkChairs == 0 then
        local tool2, toolRemote, spawnPart, hrp = getPropMakerReady()
        if not tool2 then
            warn("[PMT] Gagal siapkan PropMaker")
            stopMagnet()
            return
        end
        local base = hrp.Position + hrp.CFrame.LookVector * 4
        for i = 1, PINK_CHAIR_COUNT do
            local tempPos = base + Vector3.new((i % 5) * 1.2, math.floor(i / 5) * 1.2, 0)
            local chair = spawnGenericProp(toolRemote, spawnPart, PINK_CHAIR_NAME, PINK_CHAIR_CAT1, PINK_CHAIR_CAT2, tempPos)
            if chair then
                table.insert(pinkChairs, chair)
            end
            task.wait(0.2)
        end
    end

    if #pinkChairs == 0 then
        warn("[PMT] Gagal spawn prop.")
        stopMagnet()
        return
    end

    magnetRunning = true
    magnetTarget = target
    lockedProps = {}
    magnetBaseDirs = generateFibonacciSphere(#pinkChairs)
    magnetAngle = 0

    createAntenna(target)
    createAntennaDistanceGui(target)

    if jailBtn then
        jailBtn.Text = "Jailing..."
        jailBtn.BackgroundColor3 = Color3.fromRGB(230, 50, 50)
    end

    task.spawn(function()
        local interval = 1 / MAGNET_UPDATE_HZ
        while magnetRunning and magnetTarget == target do
            if not target or not target.Parent then
                stopMagnet()
                break
            end
            local targetChar = target.Character
            local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                ensureAntenna(target)
                ensureAntennaDistanceGui(target)

                -- Update jarak di label
                local myHead = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
                local targetHead = targetChar:FindFirstChild("Head")
                if myHead and targetHead and antennaDistanceLabel then
                    local dist = (myHead.Position - targetHead.Position).Magnitude
                    antennaDistanceLabel.Text = string.format("%.1f studs", dist)
                end

                local activeChairs = {}
                for _, prop in ipairs(pinkChairs) do
                    if prop and prop.Parent and not lockedProps[prop] then
                        table.insert(activeChairs, prop)
                    end
                end

                for _, prop in ipairs(activeChairs) do
                    local seat = getSeatFromProp(prop)
                    if seat and seat.Occupant then
                        local occupantChar = seat.Occupant.Parent
                        local occupantPlayer = occupantChar and Players:GetPlayerFromCharacter(occupantChar)
                        if occupantPlayer == target then
                            lockedProps[prop] = true
                            -- Saat target duduk, prop diterbangkan sesuai arah teleport (bukan hanya atas)
                            local flyPos = targetHRP.Position + getTeleportOffset(targetHRP)
                            local remote = getSetCFrameRemote(prop)
                            if remote then
                                task.spawn(function()
                                    pcall(function() remote:InvokeServer(CFrame.new(flyPos)) end)
                                end)
                            end
                        end
                    end
                end

                local orbitChairs = {}
                for _, prop in ipairs(activeChairs) do
                    if not lockedProps[prop] then table.insert(orbitChairs, prop) end
                end

                if #orbitChairs == 0 and #activeChairs == 0 and #pinkChairs > 0 then
                    local anyAlive = false
                    for _, prop in ipairs(pinkChairs) do
                        if prop and prop.Parent then anyAlive = true; break end
                    end
                    if not anyAlive then
                        stopMagnet()
                        break
                    end
                end

                if #orbitChairs > 0 then
                    if stickMode then
                        -- Mode tempel: semua prop aktif menempel langsung ke HRP target
                        for _, prop in ipairs(orbitChairs) do
                            local remote = getSetCFrameRemote(prop)
                            if remote then
                                task.spawn(function()
                                    pcall(function() remote:InvokeServer(CFrame.new(targetHRP.Position)) end)
                                end)
                            end
                        end
                    else
                        -- Mode orbit biasa
                        if #magnetBaseDirs ~= #orbitChairs then
                            magnetBaseDirs = generateFibonacciSphere(#orbitChairs)
                        end
                        magnetAngle = magnetAngle + MAGNET_SPEED * interval
                        local rot = CFrame.fromAxisAngle(magnetRotAxis, magnetAngle)
                        local centerPos = targetHRP.Position
                        for i, prop in ipairs(orbitChairs) do
                            local dir = magnetBaseDirs[i]
                            local rotatedDir = rot:VectorToWorldSpace(dir)
                            local pos = centerPos + rotatedDir * MAGNET_RADIUS
                            local remote = getSetCFrameRemote(prop)
                            if remote then
                                task.spawn(function()
                                    pcall(function() remote:InvokeServer(CFrame.new(pos)) end)
                                end)
                            end
                        end
                    end
                end
            end
            task.wait(interval)
        end
    end)
end

-- ═══ SPECTATOR ═══
local function startSpectate(target)
    if spectating then stopSpectate() end
    if not target or not target.Character then return end
    local hum = target.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    spectating = true
    spectateTarget = target
    Camera.CameraSubject = hum
    if spekBtn then
        spekBtn.Text = "Stop Spek"
        spekBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    end
end

local function stopSpectate()
    if not spectating then return end
    spectating = false
    local myHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if myHum then
        Camera.CameraSubject = myHum
    end
    spectateTarget = nil
    if spekBtn then
        spekBtn.Text = "Spek"
        spekBtn.BackgroundColor3 = Color3.fromRGB(30, 100, 200)
    end
end

