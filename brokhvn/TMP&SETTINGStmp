    antennaAttach0.Name = "PMTAntennaAttach0"
    antennaAttach0.Position = Vector3.new(0, 0.6, 0)
    antennaAttach0.Parent = myHead

    antennaAttach1 = Instance.new("Attachment")
    antennaAttach1.Name = "PMTAntennaAttach1"
    antennaAttach1.Position = Vector3.new(0, 0.6, 0)
    antennaAttach1.Parent = targetHead

    antennaBeam = Instance.new("Beam")
    antennaBeam.Attachment0 = antennaAttach0
