-- //                     LOOP UTAMA                               \\ --
-- // ============================================================ \\ --
task.spawn(function()
    while true do
        task.wait(0.3)
        if not Settings.AutoGift or isSelfTarget then continue end

        local targetPlayer = Players:FindFirstChild(TARGET_NAME)
        if not targetPlayer or not targetPlayer.Character then continue end

        -- Cari item giftable
        local tool = findGiftableTool()
        if not tool then continue end

        -- Equip item
        if not equipTool(tool) then continue end

        -- Teleport jika cooldown sudah lewat dan jarak terlalu jauh
        teleportNearTarget(targetPlayer)

        -- Cari prompt Gift (akan muncul di tool yang kita pegang)
        local giftPrompt = findGiftPromptNearTarget()
        if giftPrompt then
            if clickPrompt(giftPrompt) then
                -- Gift berhasil, tunggu item hilang dan lanjut ke item lain
                task.wait(0.8)
            end
        else
            task.wait(0.5)
        end
    end
end)

