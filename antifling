-- Langsung aktif saat skrip dijalankan
enableAntiFling()

-- Aktifkan ulang setiap kali karakter mati / respawn
LocalPlayer.CharacterAdded:Connect(function()
    if Settings.AntiFlingActive then
        -- Jangan langsung reconnect, tunggu sebentar agar karakter baru siap
        task.wait(0.5)
        enableAntiFling()
    end
end)

print("Anti-Fling tool loaded. Always ON, reactivates on respawn.")
