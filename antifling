Instance.new("UICorner", ToggleButton).CornerRadius = UDim.new(0, 4)

-- Ukuran frame
local expandedHeight = 26 + 28 + 4  -- 58
MainFrame.Size = UDim2.new(0, 120, 0, expandedHeight)
MainFrame.Position = UDim2.new(0.5, -60, 0, 10)

-- Minimize logic
local function applyMinimizeState()
    if Settings.Minimized then
        MainFrame.Size = UDim2.new(0, 120, 0, 26)
        MinimizeBtn.Text = "+"
        ContentFrame.Visible = false
    else
        MainFrame.Size = UDim2.new(0, 120, 0, expandedHeight)
        MinimizeBtn.Text = "-"
        ContentFrame.Visible = true
    end
end

MinimizeBtn.MouseButton1Click:Connect(function()
    Settings.Minimized = not Settings.Minimized
    applyMinimizeState()
end)

-- Toggle handler
ToggleButton.MouseButton1Click:Connect(function()
    Settings.AntiFlingActive = not Settings.AntiFlingActive
    if Settings.AntiFlingActive then
        enableAntiFling()
        ToggleButton.Text = "AntiFling: ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 160, 40)
    else
        disableAntiFling()
        ToggleButton.Text = "AntiFling: OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    end
end)

